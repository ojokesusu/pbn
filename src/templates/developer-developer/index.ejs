<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= siteName %> - Berita & Artikel Terbaru</title>
    <meta name="description" content="<%= siteDescription %>">
    <link rel="canonical" href="<%= siteUrl %>">
    <link href="https://fonts.googleapis.com/css2?family=<%= fontFamily.replace(/ /g, '+') %>:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/assets/style.css">
</head>
<body>
    <!-- Top Date Strip -->
    <div class="np-topstrip">
        <div class="np-container">
            <div class="np-topstrip-inner">
                <span class="np-topstrip-date"><%= new Date().toLocaleDateString('id-ID', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %></span>
                <div class="np-topstrip-social">
                    <span class="np-social-link">Facebook</span>
                    <span class="np-social-link">Twitter</span>
                    <span class="np-social-link">Instagram</span>
                    <span class="np-social-link">RSS</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Site Name Bar -->
    <header class="np-header">
        <div class="np-container">
            <div class="np-header-inner">
                <% if (headerStyle === 'centered') { %>
                <div class="np-header-centered">
                    <h1 class="np-site-title"><a href="<%= siteUrl %>"><%= siteName %></a></h1>
                    <p class="np-site-tagline"><%= siteDescription %></p>
                </div>
                <% } else if (headerStyle === 'minimal') { %>
                <div class="np-header-minimal">
                    <h1 class="np-site-title"><a href="<%= siteUrl %>"><%= siteName %></a></h1>
                </div>
                <% } else { %>
                <div class="np-header-left">
                    <h1 class="np-site-title"><a href="<%= siteUrl %>"><%= siteName %></a></h1>
                    <p class="np-site-tagline"><%= siteDescription %></p>
                </div>
                <% } %>
            </div>
        </div>
    </header>

    <!-- Navigation Bar -->
    <nav class="np-navbar">
        <div class="np-container">
            <button class="np-nav-toggle" aria-label="Toggle navigasi">&#9776; Menu</button>
            <ul class="np-nav-menu">
                <li class="np-nav-item"><a href="<%= siteUrl %>" class="np-nav-link np-nav-active">Beranda</a></li>
                <% categories.forEach(function(cat) { %>
                <li class="np-nav-item"><a href="/category/<%= cat.slug %>.html" class="np-nav-link"><%= cat.name %></a></li>
                <% }); %>
                <li class="np-nav-item"><a href="/about.html" class="np-nav-link">Tentang</a></li>
            </ul>
        </div>
    </nav>

    <!-- Main Content Area -->
    <main class="np-main">
        <div class="np-container">
            <div class="np-content-grid">
                <!-- Articles Column (65%) -->
                <div class="np-articles-col">
                    <% if (articles.length > 0) { %>
                    <!-- Featured Article -->
                    <article class="np-featured-card">
                        <a href="/articles/<%= articles[0].slug %>.html" class="np-featured-link">
                            <div class="np-featured-image" style="background-image: url('<%= articles[0].featuredImage || '/assets/placeholder.jpg' %>')">
                                <div class="np-featured-overlay">
                                    <span class="np-featured-cat"><%= articles[0].category %></span>
                                    <h2 class="np-featured-title"><%= articles[0].title %></h2>
                                    <div class="np-featured-meta">
                                        <span class="np-meta-author">Oleh <%= articles[0].authorName %></span>
                                        <span class="np-meta-sep">&bull;</span>
                                        <time class="np-meta-date" datetime="<%= articles[0].publishedAt %>"><%= articles[0].publishedDate %></time>
                                    </div>
                                    <p class="np-featured-excerpt"><%= articles[0].excerpt %></p>
                                </div>
                            </div>
                        </a>
                    </article>

                    <!-- Article Grid (2 columns) -->
                    <% if (articles.length > 1) { %>
                    <div class="np-articles-grid">
                        <% articles.slice(1).forEach(function(article) { %>
                        <article class="np-article-card">
                            <a href="/articles/<%= article.slug %>.html" class="np-card-link">
                                <div class="np-card-thumb" style="background-image: url('<%= article.featuredImage || '/assets/placeholder.jpg' %>')"></div>
                                <div class="np-card-body">
                                    <span class="np-card-cat"><%= article.category %></span>
                                    <h3 class="np-card-title"><%= article.title %></h3>
                                    <p class="np-card-excerpt"><%= article.excerpt %></p>
                                    <div class="np-card-meta">
                                        <span class="np-meta-author"><%= article.authorName %></span>
                                        <span class="np-meta-sep">&bull;</span>
                                        <time class="np-meta-date" datetime="<%= article.publishedAt %>"><%= article.publishedDate %></time>
                                    </div>
                                </div>
                            </a>
                        </article>
                        <% }); %>
                    </div>
                    <% } %>
                    <% } else { %>
                    <div class="np-no-articles">
                        <p>Belum ada artikel yang diterbitkan. Nantikan konten terbaru dari kami!</p>
                    </div>
                    <% } %>
                </div>

                <!-- Sidebar (35%) -->
                <aside class="np-sidebar">
                    <!-- Popular Posts -->
                    <div class="np-sidebar-widget">
                        <h3 class="np-widget-title">Artikel Populer</h3>
                        <ol class="np-popular-list">
                            <% articles.slice(0, 5).forEach(function(article, index) { %>
                            <li class="np-popular-item">
                                <span class="np-popular-num"><%= index + 1 %></span>
                                <div class="np-popular-content">
                                    <a href="/articles/<%= article.slug %>.html" class="np-popular-link"><%= article.title %></a>
                                    <time class="np-popular-date" datetime="<%= article.publishedAt %>"><%= article.publishedDate %></time>
                                </div>
                            </li>
                            <% }); %>
                        </ol>
                    </div>

                    <!-- Categories -->
                    <div class="np-sidebar-widget">
                        <h3 class="np-widget-title">Kategori</h3>
                        <ul class="np-category-list">
                            <% categories.forEach(function(cat) { %>
                            <% var catCount = articles.filter(function(a) { return a.categorySlug === cat.slug; }).length; %>
                            <li class="np-category-item">
                                <a href="/category/<%= cat.slug %>.html" class="np-category-link">
                                    <span class="np-category-name"><%= cat.name %></span>
                                    <span class="np-category-count"><%= catCount %></span>
                                </a>
                            </li>
                            <% }); %>
                        </ul>
                    </div>

                    <!-- Tags Cloud -->
                    <div class="np-sidebar-widget">
                        <h3 class="np-widget-title">Tag</h3>
                        <div class="np-tags-cloud">
                            <% var allTags = []; articles.forEach(function(a) { if (a.tags) { a.tags.split(',').forEach(function(t) { t = t.trim(); if (t && allTags.indexOf(t) === -1) allTags.push(t); }); } }); %>
                            <% allTags.slice(0, 20).forEach(function(tag) { %>
                            <span class="np-tag-item"><%= tag %></span>
                            <% }); %>
                        </div>
                    </div>
                </aside>
            </div>
        </div>
    </main>

    <!-- Footer -->
    <footer class="np-footer">
        <div class="np-container">
            <div class="np-footer-grid">
                <div class="np-footer-col">
                    <h4 class="np-footer-heading"><%= siteName %></h4>
                    <p class="np-footer-about"><%= siteDescription %></p>
                </div>
                <div class="np-footer-col">
                    <h4 class="np-footer-heading">Kategori</h4>
                    <ul class="np-footer-links">
                        <% categories.slice(0, 6).forEach(function(cat) { %>
                        <li><a href="/category/<%= cat.slug %>.html"><%= cat.name %></a></li>
                        <% }); %>
                    </ul>
                </div>
                <div class="np-footer-col">
                    <h4 class="np-footer-heading">Tautan Cepat</h4>
                    <ul class="np-footer-links">
                        <li><a href="<%= siteUrl %>">Beranda</a></li>
                        <li><a href="/about.html">Tentang Kami</a></li>
                        <li><a href="/sitemap.xml">Sitemap</a></li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="np-footer-bottom">
            <div class="np-container">
                <p class="np-copyright">&copy; <%= new Date().getFullYear() %> <%= siteName %>. Hak cipta dilindungi.</p>
            </div>
        </div>
    </footer>

    <script>
    document.addEventListener('DOMContentLoaded', function() {
        var toggle = document.querySelector('.np-nav-toggle');
        var menu = document.querySelector('.np-nav-menu');
        if (toggle && menu) {
            toggle.addEventListener('click', function() {
                menu.classList.toggle('np-nav-open');
                toggle.classList.toggle('np-toggle-active');
            });
        }
    });
    </script>
</body>
</html>
