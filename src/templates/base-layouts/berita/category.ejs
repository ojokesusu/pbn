<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= category.name %> — <%= siteName %></title>
  <meta name="description" content="<%= category.description || 'Artikel ' + category.name + ' di ' + siteName %>">
  <link rel="canonical" href="<%= siteUrl %>/category/<%= category.slug %>.html">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=<%= encodeURIComponent(fontFamily).replace(/%20/g,'+') %>:wght@400;500;600;700&family=<%= encodeURIComponent(headingFont).replace(/%20/g,'+') %>:wght@600;700;800;900&display=swap" rel="stylesheet">
  <style><%- generatedCss %></style>
</head>
<body class="{{PREFIX}}-body">

  <div class="{{PREFIX}}-topbar">
    <div class="{{PREFIX}}-container">
      <div class="{{PREFIX}}-topbar-inner">
        <span class="{{PREFIX}}-topbar-date"><%= new Date().toLocaleDateString('id-ID', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' }) %></span>
        <span class="{{PREFIX}}-topbar-tagline">Berita Terkini & Terpercaya</span>
      </div>
    </div>
  </div>

  <header class="{{PREFIX}}-header">
    <div class="{{PREFIX}}-container">
      <div class="{{PREFIX}}-header-inner">
        <a href="<%= siteUrl %>" class="{{PREFIX}}-brand">
          <span class="{{PREFIX}}-brand-text"><%= siteName %></span>
        </a>
        <div class="{{PREFIX}}-header-meta">
          <span class="{{PREFIX}}-tagline"><%= siteDescription %></span>
        </div>
      </div>
    </div>
  </header>

  <nav class="{{PREFIX}}-nav">
    <div class="{{PREFIX}}-container">
      <div class="{{PREFIX}}-nav-inner">
        <a href="<%= siteUrl %>" class="{{PREFIX}}-nav-link">Beranda</a>
        <% (categories || []).slice(0, 6).forEach(function(cat) { %>
          <a href="<%= siteUrl %>/category/<%= cat.slug %>.html" class="{{PREFIX}}-nav-link <%= cat.slug === category.slug ? '{{PREFIX}}-nav-active' : '' %>"><%= cat.name %></a>
        <% }); %>
        <a href="<%= siteUrl %>/about.html" class="{{PREFIX}}-nav-link">Tentang</a>
      </div>
    </div>
  </nav>

  <main class="{{PREFIX}}-main">
    <div class="{{PREFIX}}-container">

      <div class="{{PREFIX}}-breadcrumb">
        <a href="<%= siteUrl %>">Beranda</a>
        <span class="{{PREFIX}}-meta-sep">›</span>
        <span><%= category.name %></span>
      </div>

      <div class="{{PREFIX}}-section-header">
        <h1 class="{{PREFIX}}-section-title">Kategori: <%= category.name %></h1>
        <% if (category.description) { %><p class="{{PREFIX}}-section-desc"><%= category.description %></p><% } %>
        <div class="{{PREFIX}}-section-line"></div>
      </div>

      <% if (articles && articles.length > 0) { %>
      <section class="{{PREFIX}}-grid">
        <% articles.forEach(function(article) { %>
          <article class="{{PREFIX}}-card">
            <a href="<%= siteUrl %>/articles/<%= article.slug %>.html" class="{{PREFIX}}-card-image">
              <% if (article.featuredImage) { %>
                <img src="<%= article.featuredImage %>" alt="<%= article.title %>" loading="lazy">
              <% } else { %>
                <div class="{{PREFIX}}-card-placeholder"></div>
              <% } %>
              <% if (article.category) { %>
                <span class="{{PREFIX}}-card-badge"><%= article.category %></span>
              <% } %>
            </a>
            <div class="{{PREFIX}}-card-body">
              <h3 class="{{PREFIX}}-card-title">
                <a href="<%= siteUrl %>/articles/<%= article.slug %>.html"><%= article.title %></a>
              </h3>
              <p class="{{PREFIX}}-card-excerpt"><%= article.excerpt %></p>
              <div class="{{PREFIX}}-card-meta">
                <span><%= article.authorName %></span>
                <span class="{{PREFIX}}-meta-sep">•</span>
                <span><%= article.publishedAt %></span>
              </div>
            </div>
          </article>
        <% }); %>
      </section>
      <% } else { %>
      <div class="{{PREFIX}}-empty">
        <p>Belum ada artikel di kategori ini.</p>
      </div>
      <% } %>

    </div>
  </main>

  <footer class="{{PREFIX}}-footer">
    <div class="{{PREFIX}}-container">
      <div class="{{PREFIX}}-footer-inner">
        <div class="{{PREFIX}}-footer-col">
          <h4 class="{{PREFIX}}-footer-title"><%= siteName %></h4>
          <p class="{{PREFIX}}-footer-desc"><%= siteDescription %></p>
        </div>
        <div class="{{PREFIX}}-footer-col">
          <h4 class="{{PREFIX}}-footer-title">Kategori</h4>
          <ul class="{{PREFIX}}-footer-list">
            <% (categories || []).slice(0, 6).forEach(function(cat) { %>
              <li><a href="<%= siteUrl %>/category/<%= cat.slug %>.html"><%= cat.name %></a></li>
            <% }); %>
          </ul>
        </div>
        <div class="{{PREFIX}}-footer-col">
          <h4 class="{{PREFIX}}-footer-title">Tautan</h4>
          <ul class="{{PREFIX}}-footer-list">
            <li><a href="<%= siteUrl %>">Beranda</a></li>
            <li><a href="<%= siteUrl %>/about.html">Tentang Kami</a></li>
            <li><a href="<%= siteUrl %>/feed.xml">RSS Feed</a></li>
          </ul>
        </div>
        <% if (pbnLinks && pbnLinks.length > 0) { %>
        <div class="{{PREFIX}}-footer-col">
          <h4 class="{{PREFIX}}-footer-title">Rekomendasi</h4>
          <ul class="{{PREFIX}}-footer-list">
            <% pbnLinks.slice(0, 3).forEach(function(link) { %>
              <li><a href="<%= link.url %>" target="_blank" rel="noopener"><%= link.name %></a></li>
            <% }); %>
          </ul>
        </div>
        <% } %>
      </div>
      <div class="{{PREFIX}}-footer-bottom">
        <span>&copy; <%= new Date().getFullYear() %> <%= siteName %>. Hak Cipta Dilindungi.</span>
      </div>
    </div>
  </footer>

</body>
</html>
