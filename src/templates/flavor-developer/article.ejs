<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= article.title %> - <%= siteName %></title>
    <meta name="description" content="<%= article.excerpt %>">
    <link rel="canonical" href="<%= siteUrl %>/articles/<%= article.slug %>.html">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=<%= fontFamily.replace(/ /g, '+') %>:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/assets/style.css">
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "Article",
        "headline": "<%= article.title.replace(/"/g, '\\"') %>",
        "description": "<%= article.excerpt.replace(/"/g, '\\"') %>",
        "author": {
            "@type": "Person",
            "name": "<%= article.authorName.replace(/"/g, '\\"') %>"
        },
        "datePublished": "<%= article.publishedAt %>",
        "publisher": {
            "@type": "Organization",
            "name": "<%= siteName.replace(/"/g, '\\"') %>"
        },
        "mainEntityOfPage": {
            "@type": "WebPage",
            "@id": "<%= siteUrl %>/articles/<%= article.slug %>.html"
        }<% if (article.featuredImage) { %>,
        "image": "<%= article.featuredImage %>"<% } %>
    }
    </script>
</head>
<body class="mn-body mn-body-article">
    <header class="mn-header">
        <div class="mn-header-inner">
            <a href="<%= siteUrl %>" class="mn-site-name"><%= siteName %></a>
            <nav class="mn-nav">
                <a href="/" class="mn-nav-link">Beranda</a>
                <% categories.forEach(function(cat) { %>
                <a href="/category/<%= cat.slug %>.html" class="mn-nav-link"><%= cat.name %></a>
                <% }); %>
                <a href="/about.html" class="mn-nav-link">Tentang</a>
            </nav>
            <button class="mn-menu-toggle" aria-label="Toggle navigasi">
                <span class="mn-menu-bar"></span>
                <span class="mn-menu-bar"></span>
            </button>
        </div>
    </header>

    <main class="mn-main">
        <article class="mn-article">
            <header class="mn-article-header">
                <div class="mn-article-category">
                    <a href="/category/<%= article.categorySlug %>.html"><%= article.category %></a>
                </div>
                <h1 class="mn-article-title"><%= article.title %></h1>
                <div class="mn-article-meta">
                    <span class="mn-meta-author"><%= article.authorName %></span>
                    <span class="mn-meta-sep">&middot;</span>
                    <time class="mn-meta-date" datetime="<%= article.publishedAt %>"><%= article.publishedDate %></time>
                </div>
            </header>

            <% if (article.featuredImage) { %>
            <figure class="mn-article-hero">
                <img src="<%= article.featuredImage %>" alt="<%= article.title %>" loading="lazy">
            </figure>
            <% } %>

            <div class="mn-article-body">
                <%- article.content %>
            </div>

            <% if (article.tags && article.tags.length > 0) { %>
            <footer class="mn-article-tags">
                <% article.tags.split(',').forEach(function(tag) { tag = tag.trim(); if (!tag) return; %>
                <span class="mn-tag"><%= tag %></span>
                <% }); %>
            </footer>
            <% } %>
        </article>

        <% if (comments && comments.length > 0) { %>
        <section class="mn-comments">
            <h2 class="mn-comments-heading">Komentar (<%= comments.length %>)</h2>
            <div class="mn-comments-list">
                <% comments.forEach(function(comment) { %>
                <div class="mn-comment">
                    <div class="mn-comment-header">
                        <% if (comment.avatarUrl) { %>
                        <img src="<%= comment.avatarUrl %>" alt="" class="mn-comment-avatar" loading="lazy">
                        <% } %>
                        <div class="mn-comment-info">
                            <span class="mn-comment-author"><%= comment.authorName %></span>
                            <time class="mn-comment-date"><%= comment.date %></time>
                        </div>
                    </div>
                    <div class="mn-comment-body">
                        <p><%- comment.content %></p>
                    </div>
                </div>
                <% }); %>
            </div>
        </section>
        <% } %>
    </main>

    <footer class="mn-footer">
        <div class="mn-container">
            <p class="mn-copyright">&copy; <%= new Date().getFullYear() %> <%= siteName %></p>
        </div>
    </footer>

    <script>
    (function() {
        var toggle = document.querySelector('.mn-menu-toggle');
        var nav = document.querySelector('.mn-nav');
        if (toggle && nav) {
            toggle.addEventListener('click', function() {
                nav.classList.toggle('mn-nav-open');
                toggle.classList.toggle('mn-menu-active');
            });
        }
    })();
    </script>
</body>
</html>
